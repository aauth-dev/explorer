{
  "id": "bootstrap-ios",
  "title": "Mobile (iOS) Bootstrap",
  "description": "Agent runs on iOS with a Secure Enclave key. The PS authenticates the user and issues a bootstrap_token; the agent obtains an attestation nonce from the agent provider, generates an App Attest attestation, then POSTs to the agent provider's bootstrap_endpoint using the jkt-jwt signature scheme. The agent provider verifies the attestation, records the enclave key thumbprint as the device credential, and issues an agent token. The agent then announces its identity to the PS.",
  "spec_section": "§ Bootstrap / iOS",
  "category": "bootstrap",
  "participants": [
    {
      "id": "user",
      "label": "User",
      "type": "user"
    },
    {
      "id": "agent",
      "label": "Agent (iOS App)",
      "type": "agent"
    },
    {
      "id": "agent-provider",
      "label": "Agent Provider",
      "type": "agent"
    },
    {
      "id": "ps",
      "label": "Person Server",
      "type": "person-server"
    }
  ],
  "steps": [
    {
      "step": 1,
      "from": "agent",
      "to": "agent",
      "label": "Generate enclave key + ephemeral key",
      "method": "LOCAL",
      "url": "Secure Enclave + local key gen",
      "request_headers": {},
      "response_status": 200,
      "response_headers": {},
      "response_body": {
        "enclave_key": {
          "kty": "EC",
          "crv": "P-256",
          "x": "aW9zX2VuY2xhdmVfa2V5X3hfY29vcmRpbmF0ZQ",
          "y": "aW9zX2VuY2xhdmVfa2V5X3lfY29vcmRpbmF0ZQ",
          "kid": "urn:jkt:sha-256:NzbLsXh8uDCcd-6MNwXF4W_7noWXFZAfHkxZsRGC9Xs"
        },
        "ephemeral_key": {
          "kty": "OKP",
          "crv": "Ed25519",
          "x": "aW9zX2VwaGVtZXJhbF9zaWduaW5nX2tleV9wdWJsaWM",
          "kid": "ios-signing-key-1"
        }
      },
      "tokens": [],
      "annotations": [
        "Secure Enclave generates (or retrieves existing) P-256 key pair — hardware-bound, unexportable.",
        "Agent also generates an ephemeral Ed25519 signing key in memory for HTTP message signatures.",
        "The enclave key has a stable JWK thumbprint: urn:jkt:sha-256:<thumbprint>.",
        "Per spec: durable key lifetime is bounded by the application install (months to years).",
        "Ephemeral key lifetime is bounded by the agent token (hours to a day)."
      ]
    },
    {
      "step": 2,
      "from": "agent",
      "to": "ps",
      "label": "POST /bootstrap (hwk, agent_provider)",
      "method": "POST",
      "url": "https://ps.example/bootstrap",
      "request_headers": {
        "Content-Type": "application/json",
        "Signature-Input": "sig=(\"@method\" \"@authority\" \"@path\" \"content-digest\");created=1700000000;alg=\"ed25519\";keyid=\"ios-signing-key-1\"",
        "Signature-Key": "sig=hwk;kty=\"OKP\";crv=\"Ed25519\";x=\"aW9zX2VwaGVtZXJhbF9zaWduaW5nX2tleV9wdWJsaWM\"",
        "Signature": "sig=:aW9zX2FnZW50X3NpZ25hdHVyZV9vdmVyX3BzX2Jvb3RzdHJhcA==:",
        "Content-Digest": "sha-256=:YWJjZGVmZ2hpamtsbW5vcHFyc3R1dnd4eXoxMjM0NTY="
      },
      "request_body": {
        "agent_provider": "https://agent.example"
      },
      "response_status": 202,
      "response_headers": {
        "Content-Type": "application/json",
        "Location": "https://ps.example/bootstrap/pending/ios-abc123",
        "Retry-After": "0",
        "Cache-Control": "no-store",
        "AAuth-Requirement": "requirement=interaction; url=\"https://ps.example/interaction\"; code=\"X5Y6-Z7W8\""
      },
      "response_body": {
        "status": "pending"
      },
      "tokens": [],
      "annotations": [
        "Agent signs the PS request with hwk scheme using the ephemeral key (NOT the enclave key).",
        "The hwk scheme is always used for the PS /bootstrap request, regardless of platform.",
        "Body contains agent_provider URL — identifies which agent provider will mint the agent identity.",
        "PS responds 202 with interaction URL — user must authenticate and consent.",
        "Agent directs the user to the interaction URL (in-app browser, system browser, or deep link)."
      ]
    },
    {
      "step": 3,
      "from": "user",
      "to": "ps",
      "label": "User authenticates and approves at PS",
      "method": "GET",
      "url": "https://ps.example/interaction?code=X5Y6-Z7W8",
      "request_headers": {},
      "response_status": 200,
      "response_headers": {
        "Content-Type": "text/html"
      },
      "response_body": {
        "html": "PS consent screen — approve agent provider binding"
      },
      "tokens": [],
      "annotations": [
        "User authenticates at the PS (existing account, biometrics, password, etc.).",
        "PS displays a consent screen showing the agent provider's display name and logo.",
        "User approves allowing the agent provider to establish an account bound to this user.",
        "No identity claims are released — claims come later via the three-party flow."
      ]
    },
    {
      "step": 4,
      "from": "agent",
      "to": "ps",
      "label": "Agent polls PS — receives bootstrap_token",
      "method": "GET",
      "url": "https://ps.example/bootstrap/pending/ios-abc123",
      "request_headers": {},
      "response_status": 200,
      "response_headers": {
        "Content-Type": "application/json",
        "Cache-Control": "no-store"
      },
      "response_body": {
        "bootstrap_token": "eyJhbGciOiJFZERTQSIsImtpZCI6InBzLWtleS0xIiwidHlwIjoiYWEtYm9vdHN0cmFwK2p3dCJ9..cHNfc2lnbmF0dXJlX2lvcw"
      },
      "tokens": [
        {
          "name": "bootstrap_token",
          "typ": "aa-bootstrap+jwt",
          "raw": "eyJhbGciOiJFZERTQSIsImtpZCI6InBzLWtleS0xIiwidHlwIjoiYWEtYm9vdHN0cmFwK2p3dCJ9..cHNfc2lnbmF0dXJlX2lvcw",
          "header": {
            "alg": "EdDSA",
            "kid": "ps-key-1",
            "typ": "aa-bootstrap+jwt"
          },
          "payload": {
            "iss": "https://ps.example",
            "dwk": "aauth-person.json",
            "aud": "https://agent.example",
            "sub": "user_sub_123456",
            "cnf": {
              "jwk": {
                "kty": "OKP",
                "crv": "Ed25519",
                "x": "aW9zX2VwaGVtZXJhbF9zaWduaW5nX2tleV9wdWJsaWM",
                "kid": "ios-signing-key-1"
              }
            },
            "jti": "ios-bootstrap-123456",
            "iat": 1700000000,
            "exp": 1700000300
          },
          "signature_b64": "cHNfc2lnbmF0dXJlX2lvcw"
        }
      ],
      "annotations": [
        "PS returns the bootstrap_token — a short-lived JWT (≤5 min) directed at the agent provider.",
        "bootstrap_token.cnf.jwk = the ephemeral key (matches the hwk key from step 2).",
        "bootstrap_token.dwk = aauth-person.json — agent provider uses this to discover PS JWKS.",
        "No scope or identity claims — only binds user to ephemeral key."
      ]
    },
    {
      "step": 5,
      "from": "agent",
      "to": "agent-provider",
      "label": "GET attestation nonce from agent provider",
      "method": "GET",
      "url": "https://agent.example/attestation/nonce",
      "request_headers": {},
      "response_status": 200,
      "response_headers": {
        "Content-Type": "application/json",
        "Cache-Control": "no-store"
      },
      "response_body": {
        "nonce": "YXR0ZXN0YXRpb25fbm9uY2VfZm9yX2FwcF9hdHRlc3Q"
      },
      "tokens": [],
      "annotations": [
        "Agent fetches a single-use nonce from the agent provider for the App Attest ceremony.",
        "This endpoint is non-normative (spec §mobile-nonce-example) — mirrors the webauthn_endpoint pattern.",
        "The request is unsigned. Agent provider stores the nonce as single-use, time-limited.",
        "On iOS, the nonce is bound by computing clientDataHash over it.",
        "Implementations are free to use any transport that meets ceremony constraints."
      ]
    },
    {
      "step": 6,
      "from": "agent",
      "to": "agent",
      "label": "App Attest + jkt-jwt creation",
      "method": "LOCAL",
      "url": "DCAppAttestService + Secure Enclave",
      "request_headers": {},
      "response_status": 200,
      "response_headers": {},
      "response_body": {
        "attestation": {
          "type": "app-attest",
          "key_id": "ZW5jbGF2ZV9rZXlfaWRlbnRpZmllcl9mcm9tX3NlY3VyZV9lbmNsYXZl",
          "attestation_object": "o2NmbXRlYXBwbGVnYXR0U3RtdKJjeDVjg1kCRDCCAkAwggHGoAMCAg...",
          "client_data_hash": "Y2xpZW50X2RhdGFfaGFzaF9vdmVyX25vbmNl"
        },
        "jkt_jwt": "enclave signs jkt-jwt binding ephemeral key"
      },
      "tokens": [
        {
          "name": "jkt-jwt",
          "typ": "jkt+jwt",
          "raw": "eyJhbGciOiJFUzI1NiIsImtpZCI6InVybjpqa3Q6c2hhLTI1NjpOemJMc1hoOHVEQ2NkLTZNTndYRjRXXzdub1dYRlpBZkhreHpzUkdDOVhzIiwidHlwIjoiamt0K2p3dCJ9.eyJpc3MiOiJodHRwczovL2FnZW50LmV4YW1wbGUiLCJpYXQiOjE3MDAwMDAxMDAsImV4cCI6MTcwMDAwMDQwMCwiY25mIjp7Imp3ayI6eyJrdHkiOiJPS1AiLCJjcnYiOiJFZDI1NTE5IiwieCI6ImFXOXpYMlZ3YUdWdFpYSmhiRjl6YVdkdWFXNW5YMnRsZVY5d2RXSnNhV00iLCJraWQiOiJpb3Mtc2lnbmluZy1rZXktMSJ9fX0.ZW5jbGF2ZV9zaWduYXR1cmVfYXBwX2F0dGVzdA",
          "header": {
            "alg": "ES256",
            "kid": "urn:jkt:sha-256:NzbLsXh8uDCcd-6MNwXF4W_7noWXFZAfHkxZsRGC9Xs",
            "typ": "jkt+jwt"
          },
          "payload": {
            "iss": "https://agent.example",
            "iat": 1700000100,
            "exp": 1700000400,
            "cnf": {
              "jwk": {
                "kty": "OKP",
                "crv": "Ed25519",
                "x": "aW9zX2VwaGVtZXJhbF9zaWduaW5nX2tleV9wdWJsaWM",
                "kid": "ios-signing-key-1"
              }
            }
          },
          "signature_b64": "ZW5jbGF2ZV9zaWduYXR1cmVfYXBwX2F0dGVzdA"
        }
      ],
      "annotations": [
        "Agent calls DCAppAttestService to generate an App Attest attestation using the nonce.",
        "Attestation proves: (1) genuine Apple device, (2) app identity, (3) key in Secure Enclave.",
        "On iOS, the nonce is bound by computing clientDataHash = SHA-256(nonce).",
        "Enclave then signs a jkt-jwt: header.kid = enclave thumbprint, payload.cnf.jwk = ephemeral key.",
        "The jkt-jwt chains: enclave key → authorizes → ephemeral HTTP signing key."
      ]
    },
    {
      "step": 7,
      "from": "agent",
      "to": "agent-provider",
      "label": "POST bootstrap_endpoint (jkt-jwt + bootstrap_token + attestation)",
      "method": "POST",
      "url": "https://agent.example/bootstrap",
      "request_headers": {
        "Content-Type": "application/json",
        "Signature-Input": "sig=(\"@method\" \"@authority\" \"@path\" \"content-digest\");created=1700000100;alg=\"ed25519\";keyid=\"ios-signing-key-1\"",
        "Signature-Key": "sig=jkt-jwt;jwt=\"eyJhbGciOiJFUzI1NiIsImtpZCI6InVybjpqa3Q6c2hhLTI1NjpOemJMc1hoOHVEQ2NkLTZNTndYRjRXXzdub1dYRlpBZkhreHpzUkdDOVhzIiwidHlwIjoiamt0K2p3dCJ9...\"",
        "Signature": "sig=:aW9zX2VwaGVtZXJhbF9zaWduYXR1cmVfb3Zlcl9ib290c3RyYXA=:",
        "Content-Digest": "sha-256=:YWJjZGVmZ2hpamtsbW5vcHFyc3R1dnd4eXoxMjM0NTY="
      },
      "request_body": {
        "bootstrap_token": "eyJhbGciOiJFZERTQSIsImtpZCI6InBzLWtleS0xIiwidHlwIjoiYWEtYm9vdHN0cmFwK2p3dCJ9...",
        "attestation": {
          "type": "app-attest",
          "key_id": "ZW5jbGF2ZV9rZXlfaWRlbnRpZmllcl9mcm9tX3NlY3VyZV9lbmNsYXZl",
          "attestation_object": "o2NmbXRlYXBwbGVnYXR0U3RtdKJjeDVjg1kCRDCCAkAwggHGoAMCAg...",
          "client_data_hash": "Y2xpZW50X2RhdGFfaGFzaF9vdmVyX25vbmNl"
        }
      },
      "response_status": 200,
      "response_headers": {
        "Content-Type": "application/json"
      },
      "response_body": {
        "agent_token": "eyJhbGciOiJFZERTQSIsImtpZCI6ImFnZW50LXNlcnZlci1rZXktMSIsInR5cCI6ImFhLWFnZW50K2p3dCJ9..YWdlbnRfc2VydmVyX3NpZ25hdHVyZV9pb3M"
      },
      "tokens": [
        {
          "name": "Agent Token",
          "typ": "aa-agent+jwt",
          "raw": "eyJhbGciOiJFZERTQSIsImtpZCI6ImFnZW50LXNlcnZlci1rZXktMSIsInR5cCI6ImFhLWFnZW50K2p3dCJ9..YWdlbnRfc2VydmVyX3NpZ25hdHVyZV9pb3M",
          "header": {
            "alg": "EdDSA",
            "kid": "agent-provider-key-1",
            "typ": "aa-agent+jwt"
          },
          "payload": {
            "iss": "https://agent.example",
            "dwk": "aauth-agent.json",
            "sub": "aauth:local@agent.example",
            "ps": "https://ps.example",
            "jti": "ios-agent-token-1",
            "cnf": {
              "jwk": {
                "kty": "OKP",
                "crv": "Ed25519",
                "x": "aW9zX2VwaGVtZXJhbF9zaWduaW5nX2tleV9wdWJsaWM",
                "kid": "ios-signing-key-1"
              }
            },
            "iat": 1700000100,
            "exp": 1700086500
          },
          "signature_b64": "YWdlbnRfc2VydmVyX3NpZ25hdHVyZV9pb3M"
        }
      ],
      "signature": {
        "scheme": "jkt-jwt",
        "signature_base": "\"@method\": POST\n\"@authority\": agent.example\n\"@path\": /bootstrap\n\"content-digest\": sha-256=:YWJjZGVmZ2hpamtsbW5vcHFyc3R1dnd4eXoxMjM0NTY=\n\"@signature-params\": (\"@method\" \"@authority\" \"@path\" \"content-digest\");created=1700000100;alg=\"ed25519\";keyid=\"ios-signing-key-1\"",
        "signature_input": "sig=(\"@method\" \"@authority\" \"@path\" \"content-digest\");created=1700000100;alg=\"ed25519\";keyid=\"ios-signing-key-1\"",
        "signature_key": "sig=jkt-jwt;jwt=\"<jkt-jwt-token>\"",
        "covered_components": ["@method", "@authority", "@path", "content-digest"]
      },
      "annotations": [
        "Mobile clients use jkt-jwt scheme — the jkt-jwt header references the enclave key, cnf.jwk is the ephemeral key.",
        "The ephemeral key signs the HTTP message; the jkt-jwt proves the enclave authorized it.",
        "Body contains both the bootstrap_token (from PS) and the App Attest attestation.",
        "Agent provider verifies: (1) HTTP sig, (2) jkt-jwt enclave signature, (3) bootstrap_token via PS JWKS, (4) App Attest attestation against Apple's certificate chain + nonce.",
        "Agent provider creates binding: (ps_url, user_sub) → aauth:local@agent.example.",
        "Agent provider stores urn:jkt:sha-256:<enclave-thumbprint> as the device credential on the binding.",
        "Issues aa-agent+jwt with dwk=aauth-agent.json bound to ephemeral key via cnf.jwk."
      ]
    },
    {
      "step": 8,
      "from": "agent",
      "to": "ps",
      "label": "Announce agent identity to PS (jwt sig)",
      "method": "POST",
      "url": "https://ps.example/bootstrap",
      "request_headers": {
        "Signature-Input": "sig=(\"@method\" \"@authority\" \"@path\");created=1700000200;alg=\"ed25519\";keyid=\"ios-signing-key-1\"",
        "Signature-Key": "sig=jwt;jwt=\"eyJhbGciOiJFZERTQSIsImtpZCI6ImFnZW50LXNlcnZlci1rZXktMSIsInR5cCI6ImFhLWFnZW50K2p3dCJ9...\"",
        "Signature": "sig=:aW9zX2Fubm91bmNlbWVudF9zaWduYXR1cmU=:",
        "Content-Length": "0"
      },
      "request_body": {},
      "response_status": 204,
      "response_headers": {},
      "response_body": {},
      "tokens": [],
      "annotations": [
        "Agent announces its new identity to the PS using the jwt scheme with the agent_token.",
        "PS verifies: agent_token via agent provider JWKS, agent_token.ps = this PS, thumbprint lookup.",
        "PS records the binding between aauth:local@agent.example and the (user, agent_provider) tuple.",
        "Agent MUST make this announcement before rotating its ephemeral key (before any refresh_endpoint call)."
      ]
    },
    {
      "step": 9,
      "from": "agent",
      "to": "user",
      "label": "Bootstrap complete",
      "method": "DISPLAY",
      "url": "App UI",
      "request_headers": {},
      "response_status": 200,
      "response_headers": {},
      "response_body": {
        "message": "Bootstrap successful",
        "agent_id": "aauth:local@agent.example",
        "ps_url": "https://ps.example",
        "device_credential": "urn:jkt:sha-256:NzbLsXh8uDCcd-6MNwXF4W_7noWXFZAfHkxZsRGC9Xs"
      },
      "tokens": [],
      "annotations": [
        "Bootstrap ceremony is complete.",
        "The binding (ps_url, user_sub) → aauth:local@agent.example is established at both PS and agent provider.",
        "The enclave key thumbprint (urn:jkt:sha-256:...) is stored as the device credential.",
        "Future token renewals use the enclave key to sign jkt-jwt proofs at refresh_endpoint — no PS involved."
      ]
    }
  ]
}
